# ev-node benchmark configuration
# copy to .env and modify as needed. all values shown are defaults from ev-node.

# --- external mode (required) ---

# RPC endpoint of the pre-deployed chain
BENCH_ETH_RPC_URL=

# funded private key for spamoor to use
BENCH_PRIVATE_KEY=

# VictoriaTraces query URL for collecting trace spans
BENCH_TRACE_QUERY_URL=

# --- infrastructure ---

# target block production interval
BENCH_BLOCK_TIME=100ms

# spamoor slot cadence for tx injection
BENCH_SLOT_DURATION=250ms

# max gas per block (genesis config, hex string). leave empty for ev-reth default.
# common values: 0x1C9C380 (30M), 0x2FAF080 (50M), 0x5F5E100 (100M),
#                0x11E1A300 (300M), 0x1DCD6500 (500M), 0x3B9ACA00 (1G)
BENCH_GAS_LIMIT=

# sequencer metrics scrape interval
BENCH_SCRAPE_INTERVAL=1s

# --- load generation ---

# parallel spamoor instances injecting load
BENCH_NUM_SPAMMERS=2

# total txs each spammer sends
BENCH_COUNT_PER_SPAMMER=2000

# target tx/s per spammer
BENCH_THROUGHPUT=200

# txs sent before measurement window starts (warmup)
BENCH_WARMUP_TXS=200

# gas consumed per tx (gasburner/state-pressure only)
BENCH_GAS_UNITS_TO_BURN=1000000

# sender wallets per spammer
BENCH_MAX_WALLETS=500

# max time to wait for all txs to be sent
BENCH_WAIT_TIMEOUT=10m

# --- output ---

# path to write the structured JSON result. leave empty to skip.
BENCH_RESULT_OUTPUT=

# path to write flat github-action-benchmark entries. leave empty to skip.
BENCH_JSON_OUTPUT=

# label for the run objective (e.g. "max_mgas", "fill_target_20")
BENCH_OBJECTIVE=

# platform label (e.g. "dedicated-linux-amd64"). defaults to GOOS/GOARCH.
BENCH_PLATFORM=

# --- tags ---

# ev-reth docker image tag
EV_RETH_TAG=latest

# ev-node git commit or tag (auto-detected from vcs info if unset)
EV_NODE_TAG=

# --- ansible ---

# path to ansible playbook for environment cleanup between runs
ANSIBLE_PLAYBOOK=

# ansible inventory file
ANSIBLE_INVENTORY=
